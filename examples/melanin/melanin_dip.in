# ADCgo DIP-ADC(2) double ionization of a melanin oligomer building block (DZ basis).
#
# Recreates /home/tcstud21/melanin/dip_with_popana.sh (theADCcode adc2dip, spin "1 3",
# active "25 to 236", SYMGRP CS, fplus self-energy, lanczos iter 200).
#
#   scripts/adcgo_run.sh examples/melanin/melanin_dip.in ./adcgo-cuda
#
# DIP and SIP (melanin_sip.in) share this exact orbital space, so they produce the SAME
# FCIDUMP (melanin.fcidump) — build it once and run both solves against it.
#
&geometry
  file   zmat
&basis
  file   _basisset.dat
  cartesian on                 # GAMESS-UK cartesian GTOs -> 260 basis functions
&scf
  charge 0
  symmetry auto                # pyscf detects C1 (the molecule is genuinely 3D/folded, not
                               # planar; it cannot be made Cs without collapsing atoms -- see README)
  gate   -1095.4068317755      # GAMESS-UK RHF total energy (dip_with_popana.sh.out)
  max_cycle 200                # melanin needs many cycles to converge
&active
  active 25 to 236             # freeze MOs 1-24, drop virtuals >236 -> 212 orbitals (theADCcode "active 25 to 236")
&output
  fcidump  melanin.fcidump
  sidecar  melanin.mo.json
  manifest melanin.ref.json
&adc
  args   -dip -order 2 -solver lanczos -spin both -blocks 200
  sym    all                   # C1: one spatial irrep; -spin both -> 2 sectors (singlet, triplet) -> 2 GPUs
