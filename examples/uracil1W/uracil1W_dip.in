# ADCgo DIP-ADC(2) double ionization of uracil + 1 water (DZP, Dunning-Hay).
#
# Faithful port of ../thesis/uracil1W/dip_with_popana.sh (theADCcode `adc2dip`,
# spin "1 3", active "10 to 165", SYMGRP C1 / `adapt off`, fplus self-energy,
# lanczos iter 200). That legacy run could not finish on theADCcode in a
# reasonable walltime; this drives the same double-ionization band through ADCgo
# on bwForCluster Helix (scripts/uracil_dump.sbatch + scripts/uracil_dip.sbatch,
# or scripts/submit_uracil.sh).
#
&geometry
  file   zmat
&basis
  file   _basisset.dat
  cartesian on                 # GAMESS-UK cartesian GTOs -> 174 basis functions
&scf
  charge 0
  symmetry off                 # theADCcode ran C1 / `adapt off`: no symmetry adaption
  gate   -488.6122606854       # GAMESS-UK RHF total energy (dip_with_popana.sh.out)
  max_cycle 200
&active
  active 10 to 165             # freeze MOs 1-9, drop virtuals 166-174 -> 156 orbitals
&output
  fcidump  uracil1W.fcidump
  sidecar  uracil1W.mo.json    # C/S sidecar -> ADCgo atom-resolved 2h populations (popana)
  manifest uracil1W.ref.json
&adc
  # Whole double-ionization band via the faithful theADCcode short-recurrence
  # Lanczos (lanczos-lowmem, lowmem-block 0 = full 2h main-space block). The
  # resident device footprint is the three n×main Lanczos panels (~9 GB) PLUS the
  # uploaded block-sparse DIP operator (~30 GB, dominant) -> ~40 GB, so this needs
  # a ≥80 GB GPU (submit with ADCGO_DIP_GRES=gpu:H200:2; see scripts/uracil_dip.sbatch).
  # -spin both -> singlet + triplet (theADCcode spin "1 3") -> 2 sectors / 2 GPUs.
  args   -dip -order 2 -solver lanczos-lowmem -lowmem-block 0 -spin both -blocks 200 -backend cuda
  sym    all                   # C1: one spatial irrep
