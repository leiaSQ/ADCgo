# ADCgo DIP-ADC(2) double ionization of uracil + 2 water (DZP, Dunning-Hay).
#
# Faithful port of ../thesis/uracil2W/dip_with_popana.sh (theADCcode `adc2dip`,
# spin "1 3", active "11 to 190", SYMGRP C1 / `adapt off`, fplus self-energy,
# lanczos iter 200). That legacy run could not finish on theADCcode in a
# reasonable walltime; this drives the same double-ionization band through ADCgo
# on bwForCluster Helix (scripts/uracil_dump.sbatch + scripts/uracil_dip.sbatch,
# or scripts/submit_uracil.sh).
#
&geometry
  file   zmat
&basis
  file   _basisset.dat
  cartesian on                 # GAMESS-UK cartesian GTOs -> 200 basis functions
&scf
  charge 0
  symmetry off                 # theADCcode ran C1 / `adapt off`: no symmetry adaption
  gate   -564.6716874156       # GAMESS-UK RHF total energy (dip_with_popana.sh.out)
  max_cycle 200
&active
  active 11 to 190             # freeze MOs 1-10, drop virtuals 191-200 -> 180 orbitals
&output
  fcidump  uracil2W.fcidump
  sidecar  uracil2W.mo.json    # C/S sidecar -> ADCgo atom-resolved 2h populations (popana)
  manifest uracil2W.ref.json
&adc
  # Whole double-ionization band via the faithful theADCcode short-recurrence
  # Lanczos (lanczos-lowmem, lowmem-block 0 = full 2h main-space block). The
  # resident device footprint is the three n×main Lanczos panels (~23 GB) PLUS the
  # uploaded block-sparse DIP operator (dominant) -> ~80 GB, so this needs a large
  # GPU: submit with ADCGO_DIP_GRES=gpu:H200:2 (141 GB; see scripts/uracil_dip.sbatch).
  # -spin both -> singlet + triplet (theADCcode spin "1 3") -> 2 sectors / 2 GPUs.
  args   -dip -order 2 -solver lanczos-lowmem -lowmem-block 0 -spin both -blocks 200 -backend cuda
  sym    all                   # C1: one spatial irrep
