#!/bin/bash

symgroup="Cs"                 # symmetry line or constanti
sym_nmbs="1 2"                # symmetry numbers of non-empty irreps


#         1    2    3    4    5    6    7    8
#        ---------------------------------------
#  Cs     a'   a"
#  Ci     ag   au
#  C2      a    b
#  D2      a   b1   b2   b3
#  C2v    a1   a2   b1   b2
#  C2h    ag   bg   au   bu
#  D2h    ag  b1g  b2g  b3g   au  b1u  b2u  b3u
#
#
#############################################################################
#
# some settings:

#export OMP_NUM_THREADS=1
#the Boost library
#export  LD_LIBRARY_PATH=${LD_LIBRARY_PATH}:/home/yasen/Libs/boost_1_42_0/lib/
#module add gamess-uk/8.0/i4 pgi/10.9 intel/compiler/64/11.1.046

#module add intel/compiler/64/11.1.046 intel/mkl/11.1.046  pgi/10.9
#module add gamess-uk/7.0/i4


tdir=/tmpa/kolya/NSOB                       # temporary root-directory
# go to temporary directory
#odir=$PWD
#tdir=/$tmpa/DIP
#mkdir -p $tdir
cd $tdir

# gamess-environment:
export ed3=dfile
export ed6=vfile

# ADC-environment:
#export dfile=$tdir/dfile
#export vfile=$tdir/vfile


# normally no changes beyond this point
#
# gamess-environment:
#export ed3=dfile
#export ed6=vfile

# some output
echo This calculation was done on `hostname`

#
#
