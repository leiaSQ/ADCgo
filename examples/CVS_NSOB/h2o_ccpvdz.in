# ADCgo DIP run on H2O with a *named* basis (cc-pVDZ), full MO space (no active
# selection). Shows the named-basis path; geometry is a plain .xyz.
#
#   scripts/adcgo_run.sh examples/h2o_ccpvdz.in ./adcgo
#
&geometry
  file   h2o.xyz
&basis
  name   cc-pvdz             # resolved by pyscf; spherical GTOs (cartesian off)
&scf
  charge 0
  symmetry auto              # -> C2v
&output
  fcidump  h2o.fcidump
  sidecar  h2o.mo.json
  manifest h2o.ref.json
&adc
  args   -dip -order 2 -solver lanczos -spin both
  sym    all                 # single run over all irreps
